  "database": {
    "tables": [
      {
        "name": "alocacao",
        "columns": [
          "id",
          "dia_semana",
          "horario",
          "sala",
          "disciplina",
          "professor",
          "curso",
          "periodo",
          "turma",
          "grupo",
          "capacidade",
          "raw",
          "created_at"
        ]
      },
      {
        "name": "eventos",
        "columns": [
          "id",
          "nome",
          "data",
          "dia_semana",
          "sala",
          "horario_inicio",
          "horario_termino",
          "responsavel",
          "observacoes",
          "created_at"
        ]
      },
      {
        "name": "cancelamentos",
        "columns": [
          "id",
          "dia_semana",
          "horario",
          "sala",
          "tipo",
          "motivo",
          "created_at"
        ]
      },
      {
        "name": "user_profiles",
        "columns": [
          "id",
          "email",
          "role",
          "created_at"
        ]
      }
    ]
  },
  "features": {
    "authentication": {
      "provider": "Supabase Auth",
      "method": "Google OAuth"
    },
    "realTime": {
      "enabled": true,
      "updateInterval": 3600000,
      "features": [
        "live classroom status",
        "automatic day detection",
        "current time tracking"
      ]
    },
    "fileUpload": {
      "supportedFormats": [
        "xlsx",
        "xls"
      ],
      "types": [
        "alocacao",
        "eventos"
      ]
    },
    "totemMode": {
      "enabled": true,
      "publicAccess": true,
      "fullscreen": true,
      "autoRefresh": true
    },
    "reports": {
      "types": [
        "statistics",
        "charts",
        "occupancy analysis"
      ]
    },
    "roleBasedAccess": {
      "roles": [
        {
          "name": "user",
          "permissions": [
            "view_dashboard",
            "view_classrooms",
            "view_schedule",
            "view_events"
          ]
        },
        {
          "name": "sub-admin",
          "permissions": [
            "all_user_permissions",
            "manage_cancellations",
            "upload_spreadsheets"
          ]
        },
        {
          "name": "admin",
          "permissions": [
            "all_permissions",
            "manage_users",
            "view_reports",
            "system_configuration"
          ]
        }
      ]
    }
  },
  "styling": {
    "buttons": [
      "btn-primary",
      "btn-gold",
      "btn-ghost",
      "btn-danger",
      "btn-success",
      "btn-sm"
    ],
    "badges": [
      "badge-navy",
      "badge-gold",
      "badge-success",
      "badge-danger",
      "badge-warning",
      "badge-gray",
      "badge-info"
    ],
    "cards": [
      "card",
      "sala-card",
      "stat-box",
      "totem-sala-card"
    ],
    "responsive": {
      "breakpoints": {
        "mobile": "768px"
      },
      "mobileAdjustments": [
        "sidebar collapse",
        "single column grid",
        "reduced modal padding"
      ]
    }
  },
  "routes": {
    "main": [
      {
        "path": "dashboard",
        "component": "Dashboard",
        "access": "all"
      },
      {
        "path": "salas",
        "component": "SalasHoje",
        "access": "all"
      },
      {
        "path": "grade",
        "component": "GradeSemanal",
        "access": "all"
      },
      {
        "path": "eventos",
        "component": "Eventos",
        "access": "all"
      },
      {
        "path": "configuracoes",
        "component": "Configuracoes",
        "access": "all"
      }
    ],
    "admin": [
      {
        "path": "planilhas",
        "component": "Planilhas",
        "access": "admin"
      },
      {
        "path": "cancelamentos",
        "component": "CancelamentosAdmin",
        "access": "admin"
      },
      {
        "path": "usuarios",
        "component": "Usuarios",
        "access": "admin"
      },
      {
        "path": "relatorios",
        "component": "Relatorios",
        "access": "admin"
      }
    ],
    "public": [
      {
        "path": "?modo=totem",
        "component": "TotemView",
        "access": "public"
      }
    ]
  }
