          "type": "select",
          "options": [
            "SEGUNDA",
            "TERÇA",
            "QUARTA",
            "QUINTA",
            "SEXTA",
            "SÁBADO",
            "DOMINGO"
          ],
          "required": true
        },
        {
          "name": "sala",
          "label": "Sala",
