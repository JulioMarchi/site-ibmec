    "SalasHoje": {
      "title": "Salas - Hoje",
      "description": "Visualização em tempo real das salas ocupadas e disponíveis"
    },
    "GradeSemanal": {
      "title": "Grade Semanal Completa",
      "description": "Visão completa da grade de horários para todas as salas",
