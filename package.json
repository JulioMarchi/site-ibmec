        },
        {
          "name": "horario_termino",
          "label": "Horário Término",
          "type": "time",
          "required": true
        },
        {
          "name": "responsavel",
          "label": "Responsável",
          "type": "text",
          "required": true
        },
        {
          "name": "observacoes",
          "label": "Observações",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "id": "ModalCancelamento",
      "title": "Adicionar Cancelamento",
      "fields": [
        {
          "name": "dia_semana",
          "label": "Dia da Semana",
          "type": "select",
          "options": [
            "SEGUNDA",
            "TERÇA",
            "QUARTA",
            "QUINTA",
            "SEXTA",
            "SÁBADO",
            "DOMINGO"
          ],
          "required": true
        },
        {
          "name": "horario",
          "label": "Horário",
          "type": "text",
          "placeholder": "Ex: 08:00-10:00",
          "required": true
        },
        {
          "name": "sala",
          "label": "Sala",
          "type": "text",
          "required": true
        },
        {
          "name": "tipo",
          "label": "Tipo",
          "type": "select",
          "options": [
            {
              "value": "cancelado",
              "label": "Cancelado (temporário)"
            },
            {
              "value": "cancelado-definitivo",
              "label": "Cancelado Definitivamente"
            }
          ],
          "required": true
