        "SEGUNDA",
        "TERÇA",
        "QUARTA",
        "QUINTA",
        "SEXTA",
        "SÁBADO"
      ]
    },
    "Eventos": {
      "title": "Eventos",
      "description": "Gerenciamento de eventos e reservas especiais de salas",
      "actions": [
        "addEvento",
        "editEvento",
        "deleteEvento"
      ]
    },
    "Planilhas": {
      "title": "Importar Planilhas",
      "description": "Faça upload das planilhas de alocação de salas e eventos",
      "uploadTypes": [
        {
          "id": "alocacao",
          "label": "Planilha de Alocação",
          "description": "Excel com colunas: DIA DA SEMANA, HORÁRIO, SALA, DISCIPLINA, PROFESSOR, CURSO, PERÍODO, TURMA, GRUPO, CAPACIDADE"
        },
        {
          "id": "eventos",
          "label": "Planilha de Eventos",
          "description": "Excel com colunas: Nome do Evento, Data, Dia da Semana, Sala, Horário Inicio, Horario Termino, Responsável Reserva, Observações"
        }
      ]
    },
    "CancelamentosAdmin": {
      "title": "Gerenciar Cancelamentos",
      "description": "Adicione, edite ou remova cancelamentos de aulas",
      "actions": [
        "addCancelamento",
        "editCancelamento",
        "deleteCancelamento"
      ],
      "types": [
        {
          "value": "cancelado",
          "label": "Cancelado (temporário)"
        },
        {
          "value": "cancelado-definitivo",
          "label": "Cancelado Definitivamente"
        }
      ]
    },
    "Usuarios": {
      "title": "Gerenciar Usuários",
